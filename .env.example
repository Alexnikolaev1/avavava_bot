# Скопируй в .env для локального запуска или задай переменные в Railway -> Variables

TELEGRAM_BOT_TOKEN=123456:ABC-your-bot-token-from-BotFather
REPLICATE_API_TOKEN=r8_your-replicate-api-token

# Модель для рисования мультяшных животных (Replicate)
AVATAR_MODEL=black-forest-labs/flux-schnell

# Актуальная модель lip-sync (cjwbw/sadtalker без версии даёт 404)
SADTALKER_MODEL=lucataco/sadtalker:85c698db7c0a66d5011435d0191db323034e1da04b912a6d365833141b6a285b

# Kling Avatar — маскоты, животные, мультяшки (дороже SadTalker, но универсальнее)
KLING_AVATAR_MODEL=kwaivgi/kling-avatar-v2
KLING_AVATAR_MODE=std

# Нейрофотосессия (Replicate)
PHOTOSHOOT_HEADSHOT_MODEL=flux-kontext-apps/professional-headshot
PHOTOSHOOT_STYLE_MODEL=fofr/face-to-many:edc6439ac55af138defbca7c472b38bcdd62c61797e8e0c2fae88696cd8afb25
PHOTOSHOOT_CUSTOM_MODEL=mbukerepo/photomaker
PHOTOSHOOT_TIMEOUT_SECONDS=180

# Motion control — танец / подмена в видео
MOTION_REPLACE_MODEL=wan-video/wan-2.2-animate-replace
MOTION_CONTROL_MODEL=kwaivgi/kling-v3-motion-control
MOTION_KLING_MODE=std
MOTION_WAN_RESOLUTION=480
MOTION_MAX_VIDEO_SECONDS=15
MOTION_MAX_VIDEO_HEIGHT=720
MOTION_TIMEOUT_SECONDS=900

MAX_AUDIO_SECONDS=75
MAX_CONCURRENT_JOBS=2
USER_COOLDOWN_SECONDS=60
GENERATION_TIMEOUT_SECONDS=600
AVATAR_GENERATION_TIMEOUT_SECONDS=120

# Избранные персонажи (SQLite)
MAX_FAVORITES_PER_USER=10
DATABASE_PATH=data/bot.db

# Доступ к боту: Telegram user ID через запятую. Пусто = открыт для всех.
ALLOWED_USER_IDS=6910816316
# Несколько пользователей: ALLOWED_USER_IDS=6910816316,987654321

LOG_LEVEL=INFO
